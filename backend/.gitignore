# =====================================================================
# .gitignore — Backend del Sistema de Turnos Odontológicos
# =====================================================================

# Dependencias
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Variables de entorno (NUNCA subir credenciales reales)
.env
.env.local
.env.*.local

# Credenciales OAuth Google (NUNCA subir)
credentials.json
token.json
*-credentials.json

# Logs
logs/
*.log

# Sistema operativo
.DS_Store
Thumbs.db

# Editores
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/

# Archivos temporales
tmp/
temp/