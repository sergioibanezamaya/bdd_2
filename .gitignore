# =====================================================================
# .gitignore — Raíz del monorepo
# =====================================================================

# Archivos de sistema
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/
.idea/
*.swp
*.swo

# Variables de entorno y credenciales en cualquier subdirectorio
**/.env
**/credentials.json
**/token.json

# Logs
*.log
logs/

# Dependencias y builds (no se versionan — se regeneran con npm install)
node_modules/
**/node_modules/
dist/
**/dist/

# Cobertura de tests
coverage/
**/coverage/

# Archivos de MongoDB en memoria (binarios descargados por mongodb-memory-server)
.mongodb-binaries/
**/.mongodb-binaries/